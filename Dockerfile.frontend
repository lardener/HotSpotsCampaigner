# Build stage
FROM node:24.16.0-alpine AS builder
WORKDIR /build
COPY frontend/package*.json ./
RUN npm ci

COPY frontend .
RUN npm run build

# Runtime stage
FROM node:24.16.0-alpine
WORKDIR /app
RUN npm install -g serve

COPY --from=builder /build/dist ./dist

EXPOSE 3000
CMD ["serve", "-s", "dist", "-l", "3000"]
